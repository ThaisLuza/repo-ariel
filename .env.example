# Backend Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ariel_db

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Mercado Pago
MP_ACCESS_TOKEN=YOUR_MERCADO_PAGO_ACCESS_TOKEN
MP_WEBHOOK_URL=https://seu-dominio.com/api/webhook/payment
